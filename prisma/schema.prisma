generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  DRIVER
  STORE_OWNER
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  IN_DELIVERY
  DELIVERED
  CANCELLED
}

enum DeliveryStatus {
  PENDING_ACCEPTANCE
  ACCEPTED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  phone        String?
  role         UserRole @default(CUSTOMER)
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  addresses       Address[]
  stores          Store[]    @relation("StoreOwner")
  orders          Order[]    @relation("CustomerOrders")
  ordersDelivered Order[]    @relation("DriverOrders")
  deliveries      Delivery[]
  reviews         Review[]
}

model Address {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  label        String?
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String   @map("zip_code")
  latitude     Decimal? @db.Decimal(10, 8)
  longitude    Decimal? @db.Decimal(11, 8)
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
}

model Category {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  imageUrl  String? @map("image_url")
  sortOrder Int     @default(0) @map("sort_order")

  stores Store[]
}

model Store {
  id                  String    @id @default(cuid())
  ownerId             String    @map("owner_id")
  categoryId          String    @map("category_id")
  name                String
  slug                String    @unique
  description         String?
  imageUrl            String?   @map("image_url")
  coverImageUrl       String?   @map("cover_image_url")
  deliveryFee         Decimal   @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  minOrderValue       Decimal   @default(0) @map("min_order_value") @db.Decimal(10, 2)
  deliveryTimeMinutes Int       @default(30) @map("delivery_time_minutes")
  isActive            Boolean   @default(true) @map("is_active")
  openingHours        Json?     @map("opening_hours")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  owner             User              @relation("StoreOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  category          Category          @relation(fields: [categoryId], references: [id])
  productCategories ProductCategory[]
  products          Product[]
  orders            Order[]
  reviews           Review[]

  @@index([ownerId])
  @@index([categoryId])
  @@index([slug])
  @@index([isActive])
}

model ProductCategory {
  id        String @id @default(cuid())
  storeId   String @map("store_id")
  name      String
  sortOrder Int    @default(0) @map("sort_order")

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([storeId])
}

model Product {
  id                String    @id @default(cuid())
  storeId           String    @map("store_id")
  productCategoryId String?   @map("product_category_id")
  name              String
  description       String?
  price             Decimal   @db.Decimal(10, 2)
  imageUrl          String?   @map("image_url")
  isAvailable       Boolean   @default(true) @map("is_available")
  sortOrder         Int       @default(0) @map("sort_order")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  store           Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productCategory ProductCategory? @relation(fields: [productCategoryId], references: [id], onDelete: SetNull)
  orderItems      OrderItem[]

  @@index([storeId])
  @@index([productCategoryId])
}

model Order {
  id            String      @id @default(cuid())
  customerId    String      @map("customer_id")
  storeId       String      @map("store_id")
  driverId      String?     @map("driver_id")
  addressId     String      @map("address_id")
  status        OrderStatus @default(PENDING)
  subtotal      Decimal     @db.Decimal(10, 2)
  deliveryFee   Decimal     @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  discount      Decimal     @default(0) @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  paymentMethod String      @map("payment_method")
  observations  String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  customer User        @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Cascade)
  store    Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  driver   User?       @relation("DriverOrders", fields: [driverId], references: [id], onDelete: SetNull)
  address  Address     @relation(fields: [addressId], references: [id])
  items    OrderItem[]
  delivery Delivery?
  payments Payment[]
  reviews  Review[]

  @@index([customerId])
  @@index([storeId])
  @@index([driverId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String  @map("order_id")
  productId    String  @map("product_id")
  quantity     Int
  unitPrice    Decimal @map("unit_price") @db.Decimal(10, 2)
  observations String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model Delivery {
  id                  String         @id @default(cuid())
  orderId             String         @unique @map("order_id")
  driverId            String?        @map("driver_id")
  status              DeliveryStatus @default(PENDING_ACCEPTANCE)
  pickupAt            DateTime?      @map("pickup_at")
  deliveredAt         DateTime?      @map("delivered_at")
  estimatedDeliveryAt DateTime?      @map("estimated_delivery_at")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver User? @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([driverId])
  @@index([status])
}

model DriverLocation {
  id        String   @id @default(cuid())
  driverId  String   @unique @map("driver_id")
  latitude  Decimal  @db.Decimal(10, 8)
  longitude Decimal  @db.Decimal(11, 8)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([driverId])
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @map("order_id")
  status        PaymentStatus @default(PENDING)
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod String        @map("payment_method")
  externalId    String?       @map("external_id")
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([externalId])
}

model Review {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  userId    String   @map("user_id")
  storeId   String   @map("store_id")
  rating    Int // 1-5
  comment   String?
  type      String // "store" | "driver"
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([orderId, type])
  @@index([storeId])
  @@index([userId])
}
